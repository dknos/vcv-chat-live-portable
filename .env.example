# Copy this file to .env. Keep .env local; it is intentionally gitignored.

# Chat reader JSON. Relative paths are resolved by the process, so an absolute
# path is recommended when the bridge runs as a Windows background process.
CHAT_SOURCE=session
CHAT_SESSION_FILE=
CHAT_POLL_MS=1000
CHAT_STALE_MS=60000

# Public commands start with !rack. Direct aliases such as !tempo and !vibe
# are enabled by default.
COMMAND_PREFIX=!rack
DIRECT_COMMAND_ALIASES=1
PER_USER_COOLDOWN_MS=3000
GLOBAL_COOLDOWN_MS=350
MAX_ACTIONS_PER_BAR=8
TRUSTED_CHANNEL_IDS=
TRUSTED_DISPLAY_NAMES=

# Apply audience changes together at the next musical bar.
QUANTIZE_BARS=1
BEATS_PER_BAR=4

# VCV Rack OSC and the local OBS browser overlay.
OSC_HOST=127.0.0.1
OSC_PORT=7001
OSC_NAMESPACE=/chat
DRY_RUN=0
OVERLAY_HOST=127.0.0.1
OVERLAY_PORT=9392

# Optional runtime model control. The key stays only in .env or the process
# environment. Supported providers: openai-compatible, anthropic, gemini,
# webhook. Ollama, LM Studio, llama.cpp, vLLM, and OpenRouter can use the
# openai-compatible provider.
MODEL_CONTROL_ENABLED=0
MODEL_OWNER_ONLY=1
MODEL_TRIGGER=!ai
MODEL_PROVIDER=openai-compatible
MODEL_BASE_URL=http://127.0.0.1:11434/v1
MODEL_API_KEY=
MODEL_NAME=
MODEL_COOLDOWN_MS=15000
MODEL_TIMEOUT_MS=30000
MODEL_MAX_COMMANDS=4

# Optional `!image` generator. No image-provider key belongs in this repo; the
# configured wrapper owns its local authentication.
IMAGE_COMMANDS_ENABLED=1
IMAGE_COMMAND_COOLDOWN_MS=30000
GROK_IMAGE_COMMAND=grok-gen
GROK_IMAGE_THROUGH_WSL=0
GROK_IMAGE_LINUX_COMMAND=grok-gen
GROK_IMAGE_WSL_DISTRO=Ubuntu-22.04
GROK_IMAGE_SESSION_ROOT=

# Optional four-second YouTube sampler. Keep it owner/mod-only and use only
# audio you own or are licensed to sample.
SAMPLE_COMMANDS_ENABLED=0
SAMPLE_OWNER_ONLY=1
SAMPLE_COMMAND_COOLDOWN_MS=45000
SAMPLE_TOOLS_THROUGH_WSL=0
SAMPLE_WSL_DISTRO=Ubuntu-22.04
SAMPLE_YTDLP_COMMAND=yt-dlp
SAMPLE_FFMPEG_COMMAND=ffmpeg
SAMPLE_LINUX_OUTPUT_DIR=

# Optional ElevenLabs TTS. Leave disabled unless a runtime key is supplied.
TTS_COMMANDS_ENABLED=0
TTS_OWNER_ONLY=1
TTS_COMMAND_COOLDOWN_MS=30000
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
TTS_TOOLS_THROUGH_WSL=0
TTS_WSL_DISTRO=Ubuntu-22.04
TTS_FFMPEG_COMMAND=ffmpeg
TTS_LINUX_OUTPUT_DIR=
